# Portfolio OS — 비밀 환경변수 예시
# 실제 값은 .env (gitignore) 에만. 코드/DB/로그에 하드코딩 금지(§26, 안전 A6).
# 복사: cp config/portfolio/secrets.example.env .env  (그리고 값 채우기)

# ---- 모드 ----
KIS_MODE=paper                 # paper | live  (live 는 CEO 승인 + 체크리스트 후에만)

# ---- 한국투자증권 Open API ----
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=                # 계좌번호 (평문은 DB 저장 금지, 런타임에서만 사용)
KIS_ACCOUNT_PRODUCT_CODE=01    # 계좌상품코드 (KIS 규약)
KIS_PAPER_BASE_URL=https://openapivts.koreainvestment.com:29443   # 모의투자
KIS_LIVE_BASE_URL=https://openapi.koreainvestment.com:9443         # 실전 (live 시)

# ---- DB (portfolio_os_db) ----
PORTFOLIO_PG_HOST=localhost
PORTFOLIO_PG_PORT=5432
PORTFOLIO_PG_USER=postgres
PORTFOLIO_PG_PASSWORD=
PORTFOLIO_PG_DB=portfolio_os_db

# ---- 외부 환율 소스 (KIS 환율 미제공 시 fallback) ----
FX_PROVIDER_URL=
FX_PROVIDER_KEY=

# ---- 키움증권 REST (멀티 브로커 — KIS 와 혼용 금지, broker별 분리) ----
# 키움 REST 앱키 발급 후 채움. 계좌별: KIWOOM_ACCOUNT_{n}_*. 평문 키 로그/DB/메모리 저장 금지(.env 전용).
KIWOOM_ACCOUNT_1_APP_KEY=
KIWOOM_ACCOUNT_1_APP_SECRET=
KIWOOM_ACCOUNT_1_ACCOUNT_NO=
KIWOOM_ACCOUNT_1_MODE=paper   # paper|live (live 는 별도 확인 후)

# ---- 거시/시장 데이터 (Track B) — ECOS(한은)·FRED(미국). 키 없으면 거시 미연동(가짜 데이터 0) ----
# ECOS 인증키: https://ecos.bok.or.kr/api/  (회원가입→인증키 신청)
ECOS_API_KEY=
# FRED 키: https://fredaccount.stlouisfed.org/apikeys
FRED_API_KEY=
# 적재:   python -m main_mission.portfolio_os.macro_connect --load
# 스냅샷: python -m main_mission.portfolio_os.macro_connect --snapshot   (키 불필요)

# ---- 재무/공시 (Track C) — 금융감독원 OpenDART(공식·무료). 키 없으면 재무 미연동(가짜 데이터 0) ----
# OpenDART 인증키: https://opendart.fss.or.kr  (회원가입→인증키 신청, 무료)
# 키 없으면 정직 not_connected — 가짜 재무/저평가 점수 0(CEO 불변 원칙).
DART_API_KEY=
# corp_code 매핑 파일 경로(선택). 미설정 시 기본: data/corp_code_map.json
# DART_CORP_MAP=data/corp_code_map.json
# 절차: 1) corp_code 매핑 생성  python -m main_mission.portfolio_os.financials_connect --build-corp-map
#       2) 재무 적재(연간)      python -m main_mission.portfolio_os.financials_connect --load 005930 --year 2024
#       3) 여러 기간 일괄        python -m main_mission.portfolio_os.financials_connect --load-many 005930 --years 2023,2024 --reprts 11011,11012
#       4) 상태 확인            python -m main_mission.portfolio_os.financials_connect --status
# 가이드: docs/portfolio/dart_onboarding.md

# ---- 원격 PostgreSQL SSOT (CEO single-SSOT, 192.168.0.107) — 실제 값은 루트 .env(gitignore)에만 ----
REMOTE_PG_HOST=192.168.0.107
REMOTE_PG_PORT=5432
REMOTE_PG_USER=
REMOTE_PG_PASSWORD=
REMOTE_PG_DB=portfolio_os
